From 155957de3d18dd95cd4b46ea1a542951c3320579 Mon Sep 17 00:00:00 2001
From: Rolle Laukkarinen <roni@dude.fi>
Date: Mon, 6 Jul 2026 22:33:02 +0300
Subject: [PATCH] Add [background] animate_paused: freeze animated shader
 backgrounds

---
 config.reference.toml | 6 ++++++
 docs/config.md        | 6 ++++++
 src/backend/udev.rs   | 6 +++++-
 src/config/mod.rs     | 2 ++
 src/config/toml.rs    | 1 +
 src/config/types.rs   | 7 +++++++
 src/render/blur.rs    | 4 +++-
 src/state/mod.rs      | 3 ++-
 8 files changed, 32 insertions(+), 3 deletions(-)

diff --git a/config.reference.toml b/config.reference.toml
index 6c2aa4f..5b8c714 100644
--- a/config.reference.toml
+++ b/config.reference.toml
@@ -242,6 +242,12 @@
 # # re-evaluating the shader, so this directly scales the background's GPU cost.
 # animate_fps = 0
 
+# # Freeze animated (`u_time`) shader backgrounds entirely: no animation ticks,
+# # the time uniform never advances on its own, and animated-blur refreshes for
+# # the background stop. Camera pans/zooms still update it normally. Toggleable
+# # via config hot-reload — pause during a game or screenshare, resume after.
+# animate_paused = false
+
 [bindings]
 # # Opt out of built-in default bindings by category, for a clean slate.
 # # Normally your [keybindings]/[mouse]/[gestures] entries merge with the
diff --git a/docs/config.md b/docs/config.md
index 5eebd6e..f2b8ab4 100644
--- a/docs/config.md
+++ b/docs/config.md
@@ -573,6 +573,12 @@ Default: `0`
 
 Frame-rate cap for animated (`u_time`) shader backgrounds. 0 = every output frame (default). Slow-moving shaders look identical well below the refresh rate; between ticks the compositor reuses the composited result instead of re-evaluating the shader, so this directly scales the background's GPU cost.
 
+### `animate_paused`
+
+Default: `false`
+
+Freeze animated (`u_time`) shader backgrounds entirely: no animation ticks, the time uniform never advances on its own, and animated-blur refreshes for the background stop. Camera pans/zooms still update it normally. Toggleable via config hot-reload — pause during a game or screenshare, resume after.
+
 ## `[bindings]`
 
 ### `disable_defaults`
diff --git a/src/backend/udev.rs b/src/backend/udev.rs
index 72086d1..97469ea 100644
--- a/src/backend/udev.rs
+++ b/src/backend/udev.rs
@@ -173,7 +173,11 @@ pub(crate) fn render_if_needed(data: &mut DriftWm) {
         // tick: no event fires on an idle desktop, and without this the
         // animation would only advance alongside other redraws (stutter).
         let fps = data.config.background.animate_fps;
-        if data.render.background_is_animated && fps > 0 && !data.render.background_tick_armed {
+        if data.render.background_is_animated
+            && !data.config.background.animate_paused
+            && fps > 0
+            && !data.render.background_tick_armed
+        {
             let interval = Duration::from_secs_f64(1.0 / fps as f64);
             let elapsed = data
                 .render
