<?xml version="1.0"?>
<labwc_config>

  <theme>
    <name>Clearlooks-3.4</name>
    <cornerRadius>8</cornerRadius>
    <titlebar>
      <layout>icon:iconify,close</layout>
    </titlebar>
  </theme>

  <core>
    <gap>5</gap>
    <reuseOutputMode>yes</reuseOutputMode>
  </core>

  <focus>
    <followMouse>no</followMouse>
    <raiseOnFocus>no</raiseOnFocus>
  </focus>

  <desktops number="10">
    <names>
      <name>1</name>
      <name>2</name>
      <name>3</name>
      <name>4</name>
      <name>5</name>
      <name>6</name>
      <name>7</name>
      <name>8</name>
      <name>9</name>
      <name>10</name>
    </names>
    <popupTime>0</popupTime>
  </desktops>

  <resistance>
    <screenEdgeStrength>20</screenEdgeStrength>
    <windowEdgeStrength>20</windowEdgeStrength>
  </resistance>

  <snapping>
    <range>1</range>
    <topMaximize>no</topMaximize>
  </snapping>

  <keyboard>
    <default />

    <!-- Disable the default W-F4 close (we use W-C) -->
    <keybind key="W-F4" />

    <!-- Apps -->
    <keybind key="W-q"><action name="Execute" command="foot" /></keybind>
    <keybind key="W-c"><action name="Close" /></keybind>
    <keybind key="W-S-e"><action name="Execute" command="dolphin" /></keybind>
    <keybind key="W-k"><action name="Execute" command="dms ipc call spotlight toggle" /></keybind>

    <!-- Window management -->
    <keybind key="W-m"><action name="Iconify" /></keybind>
    <keybind key="W-t"><action name="ToggleAlwaysOnTop" /></keybind>
    <keybind key="W-l"><action name="Execute" command="bash -c '~/.config/hypr/scripts/hyprlock-wrapper.sh'" /></keybind>
    <keybind key="W-S-c"><action name="MoveToCursor" /></keybind>

    <!-- Window switcher (built-in) -->
    <keybind key="A-Tab"><action name="NextWindow" /></keybind>
    <keybind key="W-Tab"><action name="NextWindow" /></keybind>

    <!-- Workspaces -->
    <keybind key="W-1"><action name="GoToDesktop" to="1" /></keybind>
    <keybind key="W-2"><action name="GoToDesktop" to="2" /></keybind>
    <keybind key="W-3"><action name="GoToDesktop" to="3" /></keybind>
    <keybind key="W-4"><action name="GoToDesktop" to="4" /></keybind>
    <keybind key="W-5"><action name="GoToDesktop" to="5" /></keybind>
    <keybind key="W-6"><action name="GoToDesktop" to="6" /></keybind>
    <keybind key="W-7"><action name="GoToDesktop" to="7" /></keybind>
    <keybind key="W-8"><action name="GoToDesktop" to="8" /></keybind>
    <keybind key="W-9"><action name="GoToDesktop" to="9" /></keybind>
    <keybind key="W-0"><action name="GoToDesktop" to="10" /></keybind>

    <keybind key="W-S-1"><action name="SendToDesktop" to="1" follow="no" /></keybind>
    <keybind key="W-S-2"><action name="SendToDesktop" to="2" follow="no" /></keybind>
    <keybind key="W-S-3"><action name="SendToDesktop" to="3" follow="no" /></keybind>
    <keybind key="W-S-4"><action name="SendToDesktop" to="4" follow="no" /></keybind>
    <keybind key="W-S-5"><action name="SendToDesktop" to="5" follow="no" /></keybind>
    <keybind key="W-S-6"><action name="SendToDesktop" to="6" follow="no" /></keybind>
    <keybind key="W-S-7"><action name="SendToDesktop" to="7" follow="no" /></keybind>
    <keybind key="W-S-8"><action name="SendToDesktop" to="8" follow="no" /></keybind>
    <keybind key="W-S-9"><action name="SendToDesktop" to="9" follow="no" /></keybind>
    <keybind key="W-S-0"><action name="SendToDesktop" to="10" follow="no" /></keybind>

    <keybind key="W-A-Left"><action name="GoToDesktop" to="left" /></keybind>
    <keybind key="W-A-Right"><action name="GoToDesktop" to="right" /></keybind>
    <keybind key="W-S-Left"><action name="SendToDesktop" to="left" follow="no" /></keybind>
    <keybind key="W-S-Right"><action name="SendToDesktop" to="right" follow="no" /></keybind>

    <!-- Screenshots (grimblast) -->
    <keybind key="Print"><action name="Execute" command="bash -c 'grimblast --notify copysave area ~/Pictures/Screenshots/$(date +%Y%m%d_%H%M%S).png'" /></keybind>
    <keybind key="S-Print"><action name="Execute" command="bash -c 'grimblast --notify --cursor copysave active ~/Pictures/Screenshots/$(date +%Y%m%d_%H%M%S).png'" /></keybind>
    <keybind key="C-Print"><action name="Execute" command="bash -c 'grimblast --notify --cursor copysave screen ~/Pictures/Screenshots/$(date +%Y%m%d_%H%M%S).png'" /></keybind>

    <!-- Color picker -->
    <keybind key="A-S-c"><action name="Execute" command="hyprpicker -a -f hex" /></keybind>

    <!-- Volume / brightness / media keys -->
    <keybind key="XF86AudioRaiseVolume"><action name="Execute" command="wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 1%+" /></keybind>
    <keybind key="XF86AudioLowerVolume"><action name="Execute" command="wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%-" /></keybind>
    <keybind key="XF86AudioMute"><action name="Execute" command="wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle" /></keybind>
    <keybind key="XF86AudioMicMute"><action name="Execute" command="wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle" /></keybind>
    <keybind key="XF86MonBrightnessUp"><action name="Execute" command="brightnessctl -e4 -n2 set 5%+" /></keybind>
    <keybind key="XF86MonBrightnessDown"><action name="Execute" command="brightnessctl -e4 -n2 set 5%-" /></keybind>
    <keybind key="XF86AudioNext"><action name="Execute" command="playerctl next" /></keybind>
    <keybind key="XF86AudioPause"><action name="Execute" command="playerctl play-pause" /></keybind>
    <keybind key="XF86AudioPlay"><action name="Execute" command="playerctl play-pause" /></keybind>
    <keybind key="XF86AudioPrev"><action name="Execute" command="playerctl previous" /></keybind>

    <!-- Custom paste-beer -->
    <keybind key="C-S-A-v"><action name="Execute" command="bash -c '~/.local/bin/paste-beer.sh'" /></keybind>
  </keyboard>

  <mouse>
    <default />

    <!-- Super+scroll for volume; Super+Shift+scroll for desktop switching -->
    <context name="Root">
      <mousebind button="W-Up" action="Scroll"><action name="Execute" command="wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 1%+" /></mousebind>
      <mousebind button="W-Down" action="Scroll"><action name="Execute" command="wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 1%-" /></mousebind>
      <mousebind button="W-S-Up" action="Scroll"><action name="GoToDesktop" to="left" wrap="yes" /></mousebind>
      <mousebind button="W-S-Down" action="Scroll"><action name="GoToDesktop" to="right" wrap="yes" /></mousebind>
    </context>
  </mouse>

  <windowRules>
    <!-- Chromium new tab: large centered -->
    <windowRule identifier="chromium" title="New Tab.*">
      <action name="ResizeTo" width="1710" height="1200" />
      <action name="MoveToCursor" />
    </windowRule>

    <!-- Brave variants -->
    <windowRule identifier="brave-browser">
      <action name="ResizeTo" width="1710" height="1200" />
    </windowRule>
    <windowRule identifier="brave-origin-nightly">
      <action name="ResizeTo" width="1710" height="1200" />
    </windowRule>

    <!-- The Lounge IRC -->
    <windowRule identifier="chrome-irc.pulina.fi__-Default">
      <action name="ResizeTo" width="1200" height="900" />
    </windowRule>

    <!-- Telegram (ayugram) -->
    <windowRule identifier="com.ayugram.desktop">
      <action name="ResizeTo" width="550" height="620" />
    </windowRule>

    <!-- WezTerm IRC pinned right -->
    <windowRule identifier="wezterm-irc">
      <action name="ResizeTo" width="780" height="1280" />
    </windowRule>

    <!-- Conky widget: skip taskbar / always pinned -->
    <windowRule identifier="conky">
      <skipTaskbar>yes</skipTaskbar>
      <skipWindowSwitcher>yes</skipWindowSwitcher>
    </windowRule>
  </windowRules>

</labwc_config>
