#!/bin/sh
# labwc autostart - mirrors the Hyprland exec-once entries

# Wallpaper (hyprpaper still works on labwc since it's wlr-layer-shell)
hyprpaper >/dev/null 2>&1 &
~/.config/hypr/scripts/wallpaper-sync.sh >/dev/null 2>&1 &

# Idle handling (hypridle uses ext-idle-notify, works on labwc)
hypridle >/dev/null 2>&1 &

# Clipboard history watchers
wl-paste --type text --watch cliphist store >/dev/null 2>&1 &
wl-paste --type image --watch cliphist store >/dev/null 2>&1 &

# DMS (the bar / dock / launcher)
( while ! pgrep -x labwc >/dev/null; do sleep 0.5; done; sleep 1; QT_QPA_PLATFORMTHEME=gtk3 dms run >/dev/null 2>&1 ) &

# Workspace-pinned apps (delay so DMS is up first)
( sleep 8; element-nightly >/dev/null 2>&1 ) &
( sleep 8; ~/.config/hypr/scripts/launch-discord.sh >/dev/null 2>&1 ) &

# Polkit auth agent (gnome-keyring etc. need this for auth prompts)
/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 >/dev/null 2>&1 &
