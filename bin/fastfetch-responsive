#!/usr/bin/env bash
# Responsive fastfetch.
#
# Two views:
#   full     - the default, EVERYWHERE: local foot and every SSH session alike.
#   compact  - opt-in only, for the phone (Termius): the real Arch logo plus
#              short fields, each value truncated to the real column count so it
#              never wraps. The logo is always shown; width only trims values.
#
# The view is NOT auto-detected. Earlier versions picked compact for any SSH
# session, but the desktop is reached over SSH too (and a phone sets no marker
# of its own: Termius comes in as a bare xterm-256color, indistinguishable from
# a desktop SSH client). Guessing therefore made desktop SSH sessions tiny,
# which must never happen. So the rule is simple: full unless explicitly told
# otherwise. The phone asks for compact by exporting FASTFETCH_VIEW=compact
# (set once in Termius; sshd here has AcceptEnv FASTFETCH_VIEW). Nothing on the
# desktop sets it, so the desktop is always full.

set -uo pipefail

# Resolve from PATH: Homebrew installs to /opt/homebrew/bin on Apple silicon and
# /usr/local/bin on Intel, so a hardcoded /usr/bin path makes the whole script a
# silent no-op on macOS (it exits 0 when the binary is not executable).
FF=$(command -v fastfetch 2>/dev/null || printf '%s' /usr/bin/fastfetch)
CFG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/fastfetch"
FULL="$CFG_DIR/full.jsonc"
COMPACT_TPL="$CFG_DIR/compact.template.jsonc"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/fastfetch"
GEN="$CACHE_DIR/compact.jsonc"

# The Arch logo block (art + right padding 2) plus the longest key and the
# separator is ~52 cols, so a value has (cols - 52) left before it would wrap.
LOGO_OVERHEAD=52
MIN_W=8
MAX_W=40

# Never break a login shell: any missing piece falls back to plain fastfetch.
[ -x "$FF" ] || exit 0

# Full is the default. Only an explicit FASTFETCH_VIEW=compact opts out of it.
view=${FASTFETCH_VIEW:-full}
if [ "$view" != compact ] && [ -r "$FULL" ]; then
    exec "$FF" --config "$FULL" "$@"
fi

[ -r "$COMPACT_TPL" ] || exec "$FF" "$@"

cols=${COLUMNS:-0}
if ! [ "$cols" -gt 0 ] 2>/dev/null; then
    cols=$(tput cols 2>/dev/null || echo 80)
fi
[ "$cols" -gt 0 ] 2>/dev/null || cols=80

# The real Arch logo is always shown. Width only decides how hard the values
# are truncated so they sit beside the logo without wrapping.
w=$(( cols - LOGO_OVERHEAD ))
[ "$w" -lt "$MIN_W" ] && w=$MIN_W
[ "$w" -gt "$MAX_W" ] && w=$MAX_W

mkdir -p "$CACHE_DIR"
sed "s/__W__/$w/g" "$COMPACT_TPL" > "$GEN" || exec "$FF" "$@"

exec "$FF" --config "$GEN" --logo arch --logo-padding-right 2 "$@"
