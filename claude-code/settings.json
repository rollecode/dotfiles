{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/require-permission-destructive.sh",
            "timeout": 10,
            "statusMessage": "Checking for destructive commands"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/codestats-hook.py",
            "async": true
          }
        ]
      },
      {
        "matcher": "sunsama_complete_task|mcp__sunsama__sunsama_complete_task|mcp__linear__save_issue|mcp__plugin_linear_linear__save_issue",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/append-changelog.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/update-cross-channel-context.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/task-list-reminder.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "verbose": true,
  "alwaysThinkingEnabled": true,
  "showThinkingSummaries": true,
  "autoScrollEnabled": true,
  "tui": "fullscreen",
  "effortLevel": "high",
  "remoteControlAtStartup": true,
  "todoFeatureEnabled": true
}
